local function criarMarcador(cframe)
    if marcadorInicio then marcadorInicio:Destroy() end
    marcadorInicio = Instance.new("Part")
    marcadorInicio.Size = Vector3.new(4, 1, 4)
    marcadorInicio.Position = cframe.Position - Vector3.new(0, 2.5, 0)
    marcadorInicio.Anchored = true
    marcadorInicio.CanCollide = false
    marcadorInicio.Color = Color3.fromRGB(0, 255, 0)
    marcadorInicio.Material = Enum.Material.Neon
    marcadorInicio.Parent = workspace
    task.delay(10, function() if marcadorInicio then marcadorInicio:Destroy() end end)
end

local function criarBotao(texto, pos, cor, clique)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 180, 0, 32) btn.Position = pos
    btn.BackgroundColor3 = cor btn.Text = texto
    btn.TextColor3 = Color3.fromRGB(255, 255, 255) btn.Font = Enum.Font.SourceSansBold btn.TextSize = 13
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(clique)
    return btn
end

local function executarMovimento(tabelaFrames)
    if #tabelaFrames == 0 or executandoAuto then return end
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if humanoid and root then
        executandoAuto = true
        
        local pontoInicio = tabelaFrames[1].CFrame
        criarMarcador(pontoInicio)
        root.CFrame = pontoInicio -- Início preciso
        
        local tempoInicio = os.clock()
        local ponteiroFrame = 1
        
        local conexao
        conexao = RunService.Heartbeat:Connect(function()
            if not executandoAuto then conexao:Disconnect() return end
            
            local tempoAtual = os.clock() - tempoInicio
            while ponteiroFrame < #tabelaFrames and tabelaFrames[ponteiroFrame + 1].tempo <= tempoAtual do
                ponteiroFrame = ponteiroFrame + 1
            end
            
            if ponteiroFrame >= #tabelaFrames then
                executandoAuto = false
                conexao:Disconnect()
                return
            end
            
            local frameAtual = tabelaFrames[ponteiroFrame]
            
            -- MOVIMENTO HÍBRIDO
            humanoid:MoveTo(frameAtual.CFrame.Position)
            
            -- CORREÇÃO DE SEGURANÇA (Se sair mais de 3 studs, corrige a rota)
            if (root.Position - frameAtual.CFrame.Position).Magnitude > 3 then
                root.CFrame = frameAtual.CFrame
            end
            
            if frameAtual.pulando then 
                humanoid.Jump = true 
            end
        end)
    end
end

local function atualizarListaVisual()
    scrollLista:ClearAllChildren()
    Instance.new("UIListLayout", scrollLista).Padding = UDim.new(0, 4)
    if not listfiles then return end
    local arquivos = listfiles("MinhasRotasParkour")
    for _, caminho in ipairs(arquivos) do
        local nomeArquivo = caminho:match("([^/^\\]+)$")
        if nomeArquivo:sub(-5) == ".json" then
            local container = Instance.new("Frame", scrollLista)
            container.Size = UDim2.new(1, 0, 0, 25)
            container.BackgroundTransparency = 1
            local btnRota = Instance.new("TextButton", container)
            btnRota.Size = UDim2.new(0.8, 0, 1, 0)
            btnRota.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            btnRota.Text = "▶ " .. nomeArquivo:gsub(".json", "")
            btnRota.TextColor3 = Color3.fromRGB(255, 255, 255)
            btnRota.MouseButton1Click:Connect(function()
                local conteudo = readfile(caminho)
                local dados = HttpService:JSONDecode(conteudo)
                local tabela = {}
                for _, f in ipairs(dados) do
                    table.insert(tabela, {tempo=f.tempo, CFrame=CFrame.new(unpack(f.cf)), pulando=f.pulando})
                end
                executarMovimento(tabela)
            end)
            local btnDel = Instance.new("TextButton", container)
            btnDel.Size = UDim2.new(0.2, 0, 1, 0)
            btnDel.Position = UDim2.new(0.8, 2, 0, 0)
            btnDel.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            btnDel.Text = "🗑"
            btnDel.MouseButton1Click:Connect(function()
                delfile(caminho)
                atualizarListaVisual()
            end)
        end
    end
end

